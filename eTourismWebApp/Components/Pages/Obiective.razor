@page "/Obiective"
@using Microsoft.EntityFrameworkCore
@using eTourismWebApp.Data
@using Microsoft.AspNetCore.Authorization
@inject eTourismWebApp.Data.eTourismWebAppContext DbContext

<style>
    .obiectiv-card {
        transition: transform 0.2s;
        border-radius: 12px;
        overflow: hidden;
    }

    .obiectiv-card:hover {
        transform: scale(1.02);
    }

    .obiectiv-img {
        height: 250px;
        object-fit: cover;
    }

    .card-text {
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 6;
        -webkit-box-orient: vertical;
    }
</style>

<PageTitle>Obiective turistice</PageTitle>

<h1 class="mb-4">Obiective turistice</h1>

@if (obiective == null)
{
    <p><em>Se încarcă obiectivele...</em></p>
}
else if (!obiective.Any())
{
    <p><em>Nu există obiective turistice.</em></p>
}
else
{
    <MudGrid>
        @foreach (var obj in obiective)
        {
            <MudItem xs="12" sm="6">
                <div class="card shadow obiectiv-card h-100">

                    <img src="/images/obiective/@obj.Imagine"
                         class="card-img-top obiectiv-img"
                         alt="@obj.Denumire">


                    <div class="card-body d-flex flex-column">

                        <h3 class="card-title">@obj.Denumire</h3><br/>

                        <p>
                            <strong>Adresă: </strong>
                            <a href="@obj.Adresa" target="_blank" style="color: #1a73e8; text-decoration: underline;">
                                @obj.Adresa
                            </a>
                            <br />
                        </p>

                        @if (!string.IsNullOrWhiteSpace(obj.Categorie?.NumeCategorie))
                        {
                            <p>
                                <strong>Tip obiectiv:</strong>
                                @obj.Categorie.NumeCategorie
                            </p>
                        }

                        <p class="card-text">@obj.Detalii</p>

                    </div>
                </div>
            </MudItem>
        }
    </MudGrid>

    <div class="mt-3">
        <strong>Total obiective:</strong> @obiective.Count
    </div>
}

@code {

    private List<Obiectiv>? obiective;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            obiective = await DbContext.Obiective
                .AsNoTracking()
                .Include(o => o.Categorie)
                .OrderBy(o => o.Denumire)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            obiective = new List<Obiectiv>();
        }
    }
}
