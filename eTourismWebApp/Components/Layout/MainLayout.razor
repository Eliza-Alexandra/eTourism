@using Microsoft.EntityFrameworkCore.Metadata.Internal
@inject NavigationManager Navigation
@inherits LayoutComponentBase

<MudThemeProvider/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="4" Color="Color.Tertiary">

        <!-- STÂNGA -->
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Surface"
                       OnClick="@((e) => DrawerToggle())" />

        <MudButton Variant="Variant.Text" Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Home"
                   OnClick="@(() => Navigation.NavigateTo("/"))">
            Acasă
        </MudButton>

        <MudSpacer />
        
        <MudText Typo="Typo.h6" Class="ml-2" Inline="true" Color="Color.Dark">
            eTourism - Brașov
        </MudText>
        
        <!-- MAGIA -->
        <MudSpacer />

        <!-- DREAPTA -->
        <MudButton Variant="Variant.Text" Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Logout"
                   OnClick="@(() => Navigation.NavigateTo("/Identity/Account/Logout", forceLoad: true))">
            Logout
        </MudButton>

    </MudAppBar>


    <MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MyNavMenu/>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}